                <mxCell id="15" value="&lt;b&gt;Gate 1&lt;/b&gt;&lt;br/&gt;developing -&gt; verifying&lt;br/&gt;&lt;br/&gt;Code Quality:&lt;br/&gt;- Lint pass&lt;br/&gt;- Tests pass&lt;br/&gt;- Typecheck pass&lt;br/&gt;- Project-specific rules&lt;br/&gt;&lt;br/&gt;Executor: Claude (auto)&lt;br/&gt;Failure: self-fix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="700" y="100" width="220" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="&lt;b&gt;Gate 2&lt;/b&gt;&lt;br/&gt;verifying -&gt; in_review&lt;br/&gt;&lt;br/&gt;Requirement Quality:&lt;br/&gt;- Intent completeness&lt;br/&gt;- Intent consistency&lt;br/&gt;- Structured AC comparison&lt;br/&gt;- [TBD] marker check&lt;br/&gt;- Adversarial Review (M/L/XL)&lt;br/&gt;&lt;br/&gt;Executor: Claude (auto)&lt;br/&gt;Failure: self-fix" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="950" y="100" width="230" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="&lt;b&gt;Gate 3&lt;/b&gt;&lt;br/&gt;in_review -&gt; approved&lt;br/&gt;&lt;br/&gt;Human Review:&lt;br/&gt;- Review summary&lt;br/&gt;- Diff highlights&lt;br/&gt;- AC comparison result&lt;br/&gt;&lt;br/&gt;Executor: HUMAN&lt;br/&gt;BLOCKING GATE&lt;br/&gt;&lt;br/&gt;Simplified Review:&lt;br/&gt;(S complexity + 3 conditions met)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="100" width="220" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="&lt;b&gt;Gate 4 (Optional)&lt;/b&gt;&lt;br/&gt;Release create -&gt; deploy&lt;br/&gt;&lt;br/&gt;System Check:&lt;br/&gt;- Build verification&lt;br/&gt;- CI status (gh run list)&lt;br/&gt;- All CRs Gate 1/2/3 passed&lt;br/&gt;&lt;br/&gt;Executor: System&lt;br/&gt;Skip when no config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b1fa2;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="700" y="340" width="220" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="19" value="&lt;b&gt;Natural Language Quality Gate&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;checks.md supports two check types:&lt;br/&gt;- Command check: bash execution&lt;br/&gt;- Intent check: Claude NL judgment&lt;br/&gt;&lt;br/&gt;Example: &#39;All public APIs must have docs&#39;&lt;br/&gt;Claude reads changed code and judges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="950" y="360" width="280" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="&lt;b&gt;Two Quality Dimensions&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Code Quality (Gate 1/2):&lt;br/&gt;lint / test / typecheck&lt;br/&gt;&lt;br/&gt;Requirement Quality (state transitions):&lt;br/&gt;Intent completeness + consistency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="360" width="220" height="160" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="7-Change_Management" name="7-Change Management">
        <mxGraphModel dx="1323" dy="426" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="devpace - Change Management (Core Differentiator)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=18;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="350" y="10" width="800" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="&quot;Change is not an exception, it is the norm&quot; -- BizDevOps" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="400" y="50" width="600" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="Five Change Scenarios" style="swimlane;startSize=30;fillColor=#ffcdd2;strokeColor=#6c8ebf;fontColor=#333333;fontStyle=1;fontSize=13;html=1;rounded=1;whiteSpace=wrap;collapsible=0;" parent="1" vertex="1">
                    <mxGeometry x="60" y="90" width="700" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;b&gt;Add New&lt;/b&gt;&lt;br/&gt;&#39;Add feature X&#39;&lt;br/&gt;Create CR + PF impact&lt;br/&gt;+ MoS assessment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="130" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;Pause/Drop&lt;/b&gt;&lt;br/&gt;&#39;Skip X for now&#39;&lt;br/&gt;CR-&gt;paused + cascade&lt;br/&gt;+ tree update + MoS re-eval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="300" y="130" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="&lt;b&gt;Resume&lt;/b&gt;&lt;br/&gt;&#39;Bring back X&#39;&lt;br/&gt;paused-&gt;prev state&lt;br/&gt;+ capacity eval + re-verify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="520" y="130" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="&lt;b&gt;Reprioritize&lt;/b&gt;&lt;br/&gt;&#39;Do X first&#39;&lt;br/&gt;Reorder by biz priority&lt;br/&gt;+ state.md update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="220" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="&lt;b&gt;Modify&lt;/b&gt;&lt;br/&gt;&#39;X also needs Y&#39;&lt;br/&gt;Update CR + reset checks&lt;br/&gt;+ PF rework assessment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#c62828;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="300" y="220" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="Even with 1 CR, Claude&lt;br/&gt;knows which PF it belongs to.&lt;br/&gt;Change mgmt always has&lt;br/&gt;feature awareness." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="530" y="220" width="190" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="Four-Step Operation Flow" style="swimlane;startSize=30;fillColor=#c8e6c9;strokeColor=#6c8ebf;fontColor=#333333;fontStyle=1;fontSize=13;html=1;rounded=1;whiteSpace=wrap;collapsible=0;" parent="1" vertex="1">
                    <mxGeometry x="60" y="400" width="700" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="&lt;b&gt;Step 1: Triage&lt;/b&gt;&lt;br/&gt;Accept / Decline / Snooze&lt;br/&gt;Hotfix/Critical skip triage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="440" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="&lt;b&gt;Step 2: Impact Analysis&lt;/b&gt;&lt;br/&gt;Read tree -&gt; affected PF/CR&lt;br/&gt;-&gt; MoS impact -&gt; NL report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="300" y="440" width="210" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="&lt;b&gt;Step 3: Plan&lt;/b&gt;&lt;br/&gt;Propose solution&lt;br/&gt;MUST wait for human confirm&lt;br/&gt;(product loop decision)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="80" y="530" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="&lt;b&gt;Step 4: Execute&lt;/b&gt;&lt;br/&gt;Update all related files&lt;br/&gt;CR + project.md + iter&lt;br/&gt;+ state.md + git commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="300" y="530" width="210" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="accept" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" parent="1" source="12" target="13" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" parent="1" source="13" target="14" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="confirmed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" parent="1" source="14" target="15" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="19" value="&lt;b&gt;Dual Entry Design&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Entry 1: rules section 9 (auto-detect)&lt;br/&gt;Claude detects change intent in any conversation&lt;br/&gt;Keywords: &#39;skip/add/first/change&#39;&lt;br/&gt;&lt;br/&gt;Entry 2: /pace-change (explicit)&lt;br/&gt;Structured parameterized workflow&lt;br/&gt;&lt;br/&gt;Both share the same 4-step flow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="800" y="90" width="350" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="&lt;b&gt;Progressive Degradation&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;No .devpace/: instant analysis only&lt;br/&gt;Just initialized: basic impact&lt;br/&gt;Has CRs: standard CR-level analysis&lt;br/&gt;Has iterations: full capacity eval&lt;br/&gt;Rich tree: full cascade + MoS&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Strategic significance&lt;/b&gt;:&lt;br/&gt;Backup entry when session persistence&lt;br/&gt;is natively replaced - demonstrate&lt;br/&gt;change analysis value in single session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="800" y="300" width="350" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;b&gt;Paused State Design&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;- Records pre-pause state&lt;br/&gt;- Bidirectional update (tree + state.md)&lt;br/&gt;- Checkpoint-based precise recovery&lt;br/&gt;- Quality check conditional re-verify&lt;br/&gt;- Preserves ALL work artifacts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e0e0;strokeColor=#757575;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="800" y="540" width="350" height="120" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
