    <diagram id="4-End-to-End_Workflow" name="4-End-to-End Workflow">
        <mxGraphModel dx="2923" dy="426" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="devpace - End-to-End Workflow (Phase 0-5)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=18;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="400" y="10" width="800" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="Session Lifecycle + Dual Mode (Explore / Advance)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=12;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="450" y="50" width="600" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="&lt;b&gt;Phase 0: Project Init&lt;/b&gt;&lt;br/&gt;/pace-init (one-time)&lt;br/&gt;Generate .devpace/ directory&lt;br/&gt;Collect project info via dialog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="80" y="100" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;b&gt;Phase 1: Session Start&lt;/b&gt;&lt;br/&gt;(every session)&lt;br/&gt;Read state.md -&gt; 1-line report&lt;br/&gt;Wait for user instruction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="100" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;Phase 2A: Explore Mode&lt;/b&gt;&lt;br/&gt;(default)&lt;br/&gt;Free read/analyze&lt;br/&gt;No state file modification&lt;br/&gt;No state machine constraint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#66bb6a;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="30" y="300" width="250" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="&lt;b&gt;Phase 2B: Advance Mode&lt;/b&gt;&lt;br/&gt;/pace-dev trigger&lt;br/&gt;Bind to CR, follow state machine&lt;br/&gt;Auto quality checks&lt;br/&gt;Gate 1 -&gt; Gate 2 -&gt; Gate 3 (stop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#fb8c00;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="300" width="280" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="&lt;b&gt;Phase 3: Change Mgmt&lt;/b&gt;&lt;br/&gt;/pace-change (anytime)&lt;br/&gt;Triage -&gt; Impact -&gt; Plan -&gt; Execute&lt;br/&gt;5 scenarios: add/pause/resume/&lt;br/&gt;reprioritize/modify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e53935;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="940" y="180" width="280" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="&lt;b&gt;Phase 4A: Iteration Plan&lt;/b&gt;&lt;br/&gt;/pace-plan&lt;br/&gt;Close current -&gt; Plan new&lt;br/&gt;Select PFs for next iteration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b1fa2;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="-10" y="500" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="&lt;b&gt;Phase 4B: Retrospective&lt;/b&gt;&lt;br/&gt;/pace-retro&lt;br/&gt;6-step: data -&gt; dashboard&lt;br/&gt;-&gt; report -&gt; learn -&gt; handoff&lt;br/&gt;-&gt; self-assessment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#7b1fa2;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="600" width="280" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="&lt;b&gt;Phase 5: Session End&lt;/b&gt;&lt;br/&gt;(every session)&lt;br/&gt;Update state.md + CR files&lt;br/&gt;Output 3-5 line summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfd8dc;strokeColor=#546e7a;fontSize=11;fontStyle=1;" parent="1" vertex="1">
