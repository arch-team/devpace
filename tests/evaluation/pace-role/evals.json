{
  "skill_name": "pace-role",
  "description": "Behavioral evaluation for /pace-role (6 scenarios, ~18 assertions)",
  "evals": [
    {
      "id": 1,
      "name": "switch-to-pm",
      "prompt": "切换到产品经理视角",
      "expected_output": "Sets active role to PM, confirms switch, subsequent outputs adapt to PM perspective.",
      "files": [],
      "env": "ENV-ROLE-A",
      "assertions": [
        {
          "text": "Role switched to PM",
          "type": "behavior_check"
        },
        {
          "text": "Confirmation of role switch",
          "type": "output_check"
        },
        {
          "text": "Role persisted for subsequent commands",
          "type": "behavior_check"
        },
        {
          "text": "Output uses natural language",
          "type": "output_check",
          "shared_pattern": "SA-03"
        }
      ]
    },
    {
      "id": 2,
      "name": "switch-to-tester",
