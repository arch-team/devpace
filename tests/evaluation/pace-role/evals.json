      "assertions": [
        {
          "text": "Role switched to Tester",
          "type": "behavior_check"
        },
        {
          "text": "Confirmation message appropriate",
          "type": "output_check"
        },
        {
          "text": "Teaching hint on first role switch",
          "type": "output_check"
        }
      ]
    },
    {
      "id": 3,
